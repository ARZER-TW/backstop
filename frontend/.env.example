# Copy to .env to override defaults. All values are optional — config.ts ships with
# the live testnet deployment baked in, so the app works without any .env.
VITE_NETWORK=testnet
VITE_PACKAGE_ID=0x4f47075009cf926686511631f03102e7c65b09c3a0477c36d1406a1034a7f024

# Coin bound to Campaign<T>. SUI by default (demo needs only the faucet).
# For the USDC story, set the testnet USDC type:
#   VITE_COIN_TYPE=0x...::usdc::USDC
#   VITE_COIN_SYMBOL=USDC
#   VITE_COIN_DECIMALS=6
VITE_COIN_TYPE=0x2::sui::SUI
VITE_COIN_SYMBOL=SUI
VITE_COIN_DECIMALS=9
